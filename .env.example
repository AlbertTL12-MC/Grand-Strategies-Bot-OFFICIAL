# Copy this file to ".env" and fill in your real values. Never commit ".env" to GitHub.

# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Your bot's Application (Client) ID, from the same Developer Portal page
CLIENT_ID=

# Optional: if set, slash commands deploy instantly to this one server (great for testing).
# Leave blank to deploy globally (takes up to 1 hour to show up everywhere).
GUILD_ID=

# --- Backup/evacuation (OAuth) settings ---

# Your bot's Client Secret, from the same Developer Portal page (OAuth2 tab).
# Keep this private - it lets someone impersonate your bot's OAuth requests.
CLIENT_SECRET=

# The public URL your host gives you (e.g. https://your-app.up.railway.app).
# Must exactly match a "Redirect URI" you add in the Developer Portal's OAuth2 tab,
# with /oauth/callback appended, e.g. https://your-app.up.railway.app/oauth/callback
PUBLIC_URL=

# Port the small OAuth web server listens on. Most hosts set this for you automatically.
PORT=3000

